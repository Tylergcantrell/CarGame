{
  "name": "car-game-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "server": "node server/game-server.mjs",
    "server:lan": "node -e \"process.env.HOST='0.0.0.0'; import('./server/game-server.mjs')\"",
    "server:prod": "node -e \"process.env.SERVER_PROFILE='production'; process.env.HOST=process.env.HOST||'0.0.0.0'; import('./server/game-server.mjs')\"",
    "start": "node server/game-server.mjs",
    "build": "vite build",
    "build:server": "vite build --outDir server/dist --emptyOutDir",
    "preview": "vite preview --host 127.0.0.1",
    "test:sim": "node scripts/test-multiplayer-sim.mjs",
    "smoke:multiplayer": "node scripts/smoke-multiplayer.mjs",
    "stress:multiplayer": "node scripts/stress-multiplayer.mjs",
    "check:multiplayer": "node scripts/check-multiplayer-local.mjs",
    "check:stress": "node scripts/check-multiplayer-stress-local.mjs",
    "check:wan": "node scripts/check-multiplayer-wan-local.mjs"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.177.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "vite": "^7.0.0"
  }
}
